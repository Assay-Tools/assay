# Anthropic API key for evaluation agents
ANTHROPIC_API_KEY=sk-ant-...

# Database URL (SQLite for local dev)
DATABASE_URL=sqlite:///./assay.db

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Discovery — GitHub PAT for higher rate limits (5,000 req/hr vs 60)
GITHUB_TOKEN=ghp_...

# Evaluation settings
EVAL_MODEL=claude-haiku-4-5-20251001
EVAL_BATCH_SIZE=10

# Stripe payment integration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_REPORT=price_...
STRIPE_PRICE_BRIEF=price_...
STRIPE_PRICE_MONITORING=price_...
STRIPE_PRICE_SUPPORT=price_...

# Email (Migadu SMTP for transactional email)
SMTP_USER=hello@assay.tools
SMTP_PASS=your-migadu-mailbox-password
SMTP_HOST=smtp.migadu.com
SMTP_PORT=465
